---
source: crates/gauge-server/src/sqlbuild.rs
expression: built.sql
---
SELECT date_trunc('day', time) AS "time_bucket", app AS "app", event_name AS "event_name", COUNT(DISTINCT install_id) AS "unique_installs" FROM events WHERE time >= $1 AND time < $2 AND app = $3 AND (attributes->>$4) = $5 GROUP BY 1, 2, 3 ORDER BY "unique_installs" DESC LIMIT 101
